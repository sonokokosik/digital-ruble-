<!DOCTYPE html>

<html lang="ru">

<head>

<meta charset="UTF-8" />

<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>Цифровой рубль. Эволюция доверия</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<style>

:root {

  --bg-main:#2C2C2C;

  --steel:#4A6572;

  --turquoise:#2F7F7F;

  --graphite:#3A3A3A;

  --text-light:#EAEAEA;

}

* {box-sizing:border-box; margin:0; padding:0;}

body {

  font-family:'Inter',sans-serif;

  background:var(--bg-main);

  color:var(--text-light);

  line-height:1.6;

}

header {

  padding:40px 60px;

  border-bottom:1px solid var(--graphite);

}

h1 {font-weight:600; font-size:32px;}

.subtitle {margin-top:8px; color:#b0b0b0;}

nav {

  margin-top:20px;

  display:flex;

  gap:20px;

}

nav a {

  text-decoration:none;

  color:var(--steel);

  font-weight:500;

  transition:0.3s;

}

nav a:hover {color:var(--turquoise);}

section {padding:60px;}

h2 {margin-bottom:30px; font-weight:600;}

.timeline {

  display:flex;

  justify-content:space-between;

  gap:20px;

  flex-wrap:wrap;

}

.timeline-item {

  flex:1;

  min-width:200px;

  padding:20px;

  border:1px solid var(--graphite);

  border-radius:8px;

  text-align:center;

  cursor:pointer;

  transition:0.3s;

}

.timeline-item:hover {

  border-color:var(--turquoise);

  transform:translateY(-5px);

}

.timeline-item:hover span {color:var(--turquoise);}

.timeline-item span {

  display:block;

  margin-top:10px;

  font-size:14px;

  color:#aaa;

}

.tooltip {

  margin-top:30px;

  min-height:60px;

  padding:20px;

  background:var(--graphite);

  border-radius:8px;

}

.matrix {

  display:grid;

  grid-template-columns:repeat(auto-fit,minmax(250px,1fr));

  gap:20px;

}

.card {

  background:var(--graphite);

  padding:25px;

  border-radius:10px;

  transition:0.3s;

}

.card:hover {

  transform:translateY(-6px);

  box-shadow:0 10px 25px rgba(0,0,0,0.4);

}

.card h3 {margin-bottom:15px;}

.card ul {list-style:none;}

.card ul li {margin-bottom:8px; font-size:14px;}

.hash-visual {

  display:flex;

  align-items:center;

  gap:20px;

  flex-wrap:wrap;

}

.hash-box {

  background:var(--graphite);

  padding:20px;

  border-radius:8px;

}

input {

  padding:10px;

  border-radius:6px;

  border:none;

  width:250px;

}

.cta {

  text-align:center;

  padding:80px 40px;

  border-top:1px solid var(--graphite);

}

button {

  padding:12px 25px;

  background:var(--turquoise);

  border:none;

  border-radius:6px;

  color:white;

  cursor:pointer;

  transition:0.3s;

}

button:hover {background:var(--steel);}

</style>

</head>

<body>

<header>

  <h1>Цифровой рубль. Эволюция доверия</h1>

  <p class="subtitle">Интерактивный гид по третьей форме денег: от истории к безопасности.</p>

  <nav>

    <a href="#evolution">Эволюция</a>

    <a href="#comparison">Сравнение</a>

    <a href="#security">Безопасность</a>

  </nav>

</header>

<section id="evolution">

  <h2>Эволюция: от чешуйки до кода</h2>

  <div class="timeline">

    <div class="timeline-item" onmouseover="showText(1)">

      🪙 Монеты

      <span>Материальная ценность</span>

    </div>

    <div class="timeline-item" onmouseover="showText(2)">

      💵 Банкноты

      <span>Государственная гарантия</span>

    </div>

    <div class="timeline-item" onmouseover="showText(3)">

      💳 Карты

      <span>Дематериализация</span>

    </div>

    <div class="timeline-item" onmouseover="showText(4)">

      📱 Цифровой рубль

      <span>Программируемые деньги</span>

    </div>

  </div>

  <div class="tooltip" id="tooltip">Наведите курсор на этап эволюции.</div>

</section>

<section id="comparison">

  <h2>Наличные vs Безналичные vs Цифровые</h2>

  <div class="matrix">

    <div class="card">

      <h3>Наличные</h3>

      <ul>

        <li>Где хранятся: В кошельке</li>

        <li>Проценты: Нет</li>

        <li>Офлайн-доступ: Да</li>

        <li>Анонимность: Высокая</li>

      </ul>

    </div>

    <div class="card">

      <h3>Безналичные</h3>

      <ul>

        <li>Где хранятся: В банке</li>

        <li>Проценты: Возможны</li>

        <li>Офлайн-доступ: Нет</li>

        <li>Анонимность: Низкая</li>

      </ul>

    </div>

    <div class="card">

      <h3>Цифровой рубль</h3>

      <ul>

        <li>Где хранятся: На платформе ЦБ</li>

        <li>Проценты: Нет</li>

        <li>Офлайн-доступ: Планируется</li>

        <li>Анонимность: Ограниченная</li>

      </ul>

    </div>

  </div>

</section>

<section id="security">

  <h2>Как работает защита</h2>

  <div class="hash-visual">

    <div>

      <input type="text" id="inputData" placeholder="Введите данные..." oninput="generateHash()">

    </div>

    <div class="hash-box" id="hashOutput">

      Хэш появится здесь

    </div>

  </div>

</section>

<section class="cta">

  <h2>Будущее денег — это доверие к коду</h2>

  <button onclick="alert('Спасибо за интерес к цифровому рублю!')">Узнать больше</button>

</section>

<script>

function showText(step) {

  const texts = {

    1: "Монеты имели собственную материальную ценность — металл.",

    2: "Банкноты стали обеспечиваться государством.",

    3: "Карты позволили отказаться от физической формы денег.",

    4: "Цифровой рубль — это новая форма национальной валюты в цифровом виде."

  };

  document.getElementById("tooltip").innerText = texts[step];

}

function generateHash() {

  const input = document.getElementById("inputData").value;

  let hash = 0;

  for (let i = 0; i < input.length; i++) {

    hash = ((hash << 5) - hash) + input.charCodeAt(i);

    hash |= 0;

  }

  document.getElementById("hashOutput").innerText = "Хэш: " + hash;

}

</script>
<section style="padding:60px;">

<h2 style="margin-bottom:30px;">Интерактив: проверь своё понимание</h2>

<div style="margin-bottom:50px;">

<h3>Миф или факт?</h3>

<p id="mythText">Цифровой рубль — это криптовалюта.</p>

<button onclick="answerMyth(false)">Миф</button>

<button onclick="answerMyth(true)">Факт</button>

<p id="mythResult" style="margin-top:15px;font-weight:600;"></p>

</div>

<div style="margin-bottom:50px;">

<h3>Программируемые деньги</h3>

<p>Вам пришла социальная выплата.</p>

<button onclick="pay('food')">Купить продукты</button>

<button onclick="pay('crypto')">Купить криптовалюту</button>

<p id="payResult" style="margin-top:15px;font-weight:600;"></p>

</div>

<div style="margin-bottom:50px;">

<h3>Ваше мнение</h3>

<p>Вы бы пользовались цифровым рублём?</p>

<button onclick="vote('yes')">Да</button>

<button onclick="vote('no')">Нет</button>

<p id="voteResult" style="margin-top:15px;font-weight:600;"></p>

</div>

</section>

<script>

let yes = 0;

let no = 0;

function answerMyth(isFact) {

  const result = document.getElementById("mythResult");

  if (!isFact) {

    result.innerText = "Верно ✔ Это НЕ криптовалюта. Его выпускает Центральный банк.";

  } else {

    result.innerText = "Неверно ❌ Цифровой рубль — это государственная валюта.";

  }

}

function pay(type) {

  const result = document.getElementById("payResult");

  if (type === "food") {

    result.innerText = "Платёж разрешён ✔";

  } else {

    result.innerText = "Операция отклонена ❌ Эти деньги можно тратить только на продукты.";

  }

}

function vote(choice) {

  if (choice === "yes") yes++;

  if (choice === "no") no++;

  document.getElementById("voteResult").innerText =

    "За: " + yes + " | Против: " + no;

}

</script>
  <section style="padding:60px;">
    <section style="padding:60px;">

<h2 style="margin-bottom:30px;">Почему цифровые деньги сложно подделать</h2>

<div style="margin-bottom:30px;">
<p><b>Блокчейн</b> — это база данных, где информация хранится в виде цепочки блоков.  
Каждый блок содержит данные о транзакциях и специальный криптографический код — <b>хэш</b>, который связывает его с предыдущим блоком.</p>

<p>Если изменить хотя бы один блок, вся цепочка перестанет совпадать.</p>
</div>

<div id="blockchain" style="display:flex;gap:20px;flex-wrap:wrap;margin-bottom:30px;">

<div class="card" id="block1">
<h3>Блок 1</h3>
<p>Перевод: 100 ₽</p>
<p>hash: A7F3D</p>
</div>

<div class="card" id="block2">
<h3>Блок 2</h3>
<p>Перевод: 250 ₽</p>
<p>hash: B81KD</p>
</div>

<div class="card" id="block3">
<h3>Блок 3</h3>
<p>Перевод: 400 ₽</p>
<p>hash: X91PL</p>
</div>

</div>

<button style="background:#c0392b;" onclick="hackBlock()">Взломать блок</button>

<p id="hackResult" style="margin-top:20px;font-weight:600;"></p>

</section>
<h2 style="margin-bottom:30px;">Статистика мошенничества в России</h2>

<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:20px;margin-bottom:40px;">

<div style="background:#3A3A3A;padding:20px;border-radius:10px;">
<h3>2021</h3>
<p>≈ 6,5 млрд ₽ ущерба</p>
<p>≈ 400 тыс. преступлений</p>
</div>

<div style="background:#3A3A3A;padding:20px;border-radius:10px;">
<h3>2022</h3>
<p>≈ 14 млрд ₽ ущерба</p>
<p>Рост телефонного мошенничества</p>
